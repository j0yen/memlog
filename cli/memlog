#!/usr/bin/env python3
"""memlog — read/write /dev/memlog, per PRD-memlog.md §4.2.

Subcommands:
  show [--since DUR] [--uid UID] [--limit N] [--format json|raw]
  tail               (read all and print, then exit; -f deferred to v0.2)
  stats              (ioctl STATS)
  clear              (ioctl CLEAR; root only)
  write < FILE       (read CBOR blob on stdin, write one record)

The CBOR blob is opaque to the kernel; this CLI does not encode CBOR for
you. Pair with the libmemlog bindings (deferred) for typed writers.
"""

import argparse
import array
import ctypes
import fcntl
import json
import os
import struct
import sys
import time
from pathlib import Path

DEV = "/dev/memlog"

# UAPI mirror — keep in sync with include/uapi/linux/memlog.h
MEMLOG_RECORD_MAX = 64 * 1024
MEMLOG_RECORD_MAGIC = 0x4D4C4F47  # 'MLOG'
MEMLOG_SCHEMA_VERSION = 1

# struct memlog_record_header — packed
# u32 magic, u32 schema_version, u32 length, u32 _reserved,
# u64 ts_ns, u64 seq, u32 uid, u32 pid, u8 session_id[16]
HEADER_FMT = "<IIIIQQII16s"
HEADER_SIZE = struct.calcsize(HEADER_FMT)
assert HEADER_SIZE == 56, HEADER_SIZE

# struct memlog_stats — packed
# u64 total_writes, u64 total_evictions, u64 records_in_ring,
# u32 ring_bytes, u32 ring_capacity, u64 oldest_ts_ns, u64 newest_ts_ns
STATS_FMT = "<QQQIIQQ"
STATS_SIZE = struct.calcsize(STATS_FMT)
assert STATS_SIZE == 48, STATS_SIZE

# ioctl numbers — _IOC encoding: dir(2) | size(14) | type(8) | nr(8)
_IOC_NRBITS = 8
_IOC_TYPEBITS = 8
_IOC_SIZEBITS = 14
_IOC_DIRBITS = 2
_IOC_NRSHIFT = 0
_IOC_TYPESHIFT = _IOC_NRSHIFT + _IOC_NRBITS
_IOC_SIZESHIFT = _IOC_TYPESHIFT + _IOC_TYPEBITS
_IOC_DIRSHIFT = _IOC_SIZESHIFT + _IOC_SIZEBITS
_IOC_NONE = 0
_IOC_WRITE = 1
_IOC_READ = 2

def _IOC(dir_, typ, nr, size):
    return (dir_ << _IOC_DIRSHIFT) | (typ << _IOC_TYPESHIFT) | (nr << _IOC_NRSHIFT) | (size << _IOC_SIZESHIFT)

def _IO(t, n):    return _IOC(_IOC_NONE, t, n, 0)
def _IOR(t, n, s):return _IOC(_IOC_READ, t, n, s)
def _IOW(t, n, s):return _IOC(_IOC_WRITE, t, n, s)

T = 0xCB  # MEMLOG_IOCTL_BASE
MEMLOG_IOCTL_STATS          = _IOR(T, 1, STATS_SIZE)
MEMLOG_IOCTL_CLEAR          = _IO (T, 2)
MEMLOG_IOCTL_SET_RING_SIZE  = _IOW(T, 3, 4)
MEMLOG_IOCTL_FILTER_UID     = _IOW(T, 4, 4)
MEMLOG_IOCTL_GET_VERSION    = _IOR(T, 5, 4)

def parse_duration(s: str) -> float:
    """'10m' -> 600, '2h' -> 7200, '30s' -> 30, '1d' -> 86400."""
    units = {"s": 1, "m": 60, "h": 3600, "d": 86400}
    if s and s[-1] in units:
        return float(s[:-1]) * units[s[-1]]
    return float(s)

def open_dev(mode="rb"):
    try:
        return open(DEV, mode, buffering=0)
    except FileNotFoundError:
        sys.exit(f"memlog: {DEV} not present — is the module loaded?")
    except PermissionError as e:
        sys.exit(f"memlog: {e} — add yourself to the 'memlog' group or run as root.")

def cmd_stats(args):
    with open_dev("rb") as f:
        buf = array.array("b", b"\x00" * STATS_SIZE)
        fcntl.ioctl(f, MEMLOG_IOCTL_STATS, buf, True)
        st = struct.unpack(STATS_FMT, buf.tobytes())
        out = {
            "total_writes": st[0],
            "total_evictions": st[1],
            "records_in_ring": st[2],
            "ring_bytes": st[3],
            "ring_capacity": st[4],
            "oldest_ts_ns": st[5],
            "newest_ts_ns": st[6],
        }
        if args.format == "json":
            print(json.dumps(out, indent=2))
        else:
            for k, v in out.items():
                print(f"{k:18s} {v}")

def cmd_clear(args):
    with open_dev("rb") as f:
        fcntl.ioctl(f, MEMLOG_IOCTL_CLEAR)
    print("memlog: ring cleared")

def cmd_show(args):
    since_ns = 0
    if args.since:
        since_ns = int((time.time() - parse_duration(args.since)) * 1e9)

    with open_dev("rb") as f:
        if args.uid is not None:
            buf = struct.pack("<I", args.uid)
            fcntl.ioctl(f, MEMLOG_IOCTL_FILTER_UID, buf)

        count = 0
        while True:
            blob = f.read(HEADER_SIZE + MEMLOG_RECORD_MAX)
            if not blob:
                break
            if len(blob) < HEADER_SIZE:
                sys.exit(f"memlog: short read ({len(blob)} bytes)")
            (magic, schema, length, _, ts_ns, seq, uid, pid, sid) = struct.unpack(
                HEADER_FMT, blob[:HEADER_SIZE]
            )
            if magic != MEMLOG_RECORD_MAGIC:
                sys.exit(f"memlog: bad magic 0x{magic:08x} at seq {seq}")
            payload = blob[HEADER_SIZE:HEADER_SIZE + length]
            if ts_ns < since_ns:
                continue
            if args.format == "json":
                rec = {
                    "seq": seq, "ts_ns": ts_ns, "uid": uid, "pid": pid,
                    "session_id": sid.hex(), "schema_version": schema,
                    "length": length, "payload_b64": _b64(payload),
                }
                print(json.dumps(rec))
            else:
                print(f"--- seq={seq} ts_ns={ts_ns} uid={uid} pid={pid} "
                      f"len={length} session_id={sid.hex()}")
                sys.stdout.buffer.write(payload)
                sys.stdout.buffer.write(b"\n")
            count += 1
            if args.limit and count >= args.limit:
                break

def _b64(b):
    import base64
    return base64.b64encode(b).decode("ascii")

def cmd_write(args):
    data = sys.stdin.buffer.read()
    if not data:
        sys.exit("memlog: nothing on stdin")
    if len(data) > MEMLOG_RECORD_MAX:
        sys.exit(f"memlog: payload {len(data)} > MEMLOG_RECORD_MAX {MEMLOG_RECORD_MAX}")
    with open_dev("wb") as f:
        n = f.write(data)
    print(f"memlog: wrote {n} bytes")

def cmd_version(args):
    with open_dev("rb") as f:
        buf = array.array("b", b"\x00" * 4)
        fcntl.ioctl(f, MEMLOG_IOCTL_GET_VERSION, buf, True)
        v = struct.unpack("<I", buf.tobytes())[0]
        print(f"memlog schema_version: {v}")

def main():
    p = argparse.ArgumentParser(description=__doc__,
                                formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = p.add_subparsers(dest="cmd", required=True)

    s = sub.add_parser("show"); s.set_defaults(fn=cmd_show)
    s.add_argument("--since"); s.add_argument("--uid", type=int)
    s.add_argument("--limit", type=int)
    s.add_argument("--format", choices=("raw", "json"), default="raw")

    s = sub.add_parser("stats"); s.set_defaults(fn=cmd_stats)
    s.add_argument("--format", choices=("text", "json"), default="text")

    s = sub.add_parser("clear"); s.set_defaults(fn=cmd_clear)
    s = sub.add_parser("write"); s.set_defaults(fn=cmd_write)
    s = sub.add_parser("version"); s.set_defaults(fn=cmd_version)

    args = p.parse_args()
    args.fn(args)

if __name__ == "__main__":
    main()
